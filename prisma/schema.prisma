generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id               String           @id @default(cuid())
  name             String
  users            User[]
  departments      Department[]
  clients          Client[]
  projects         Project[]
  timeClockEntries TimeClockEntry[]
  conversations     Conversation[]
  calendarEvents  CalendarEvent[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  email          String       @unique
  name           String
  role           UserRole     @default(DEPARTMENT_USER)
  isActive       Boolean      @default(true)

  assignedTasks    Task[]           @relation("TaskAssignee")
  createdTasks     Task[]           @relation("TaskCreator")
  notes            Note[]
  notifications    Notification[]
  timeLogs         TimeLog[]
  timeClockEntries TimeClockEntry[]
  uploadedFiles    File[]
  lastMarkedUpFiles File[]          @relation("FileLastMarkedUpBy")
  uploadedPhotos   Photo[]
  chatParticipants ConversationParticipant[]
  sentChatMessages ChatMessage[]
  createdConversations Conversation[] @relation("ConversationCreator")
  calendarEvents CalendarEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([departmentId])
}

model Department {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  name           String
  workflowKey    DepartmentKey
  sortOrder      Int
  users          User[]
  projects       Project[]
  tasks          Task[]
  timeLogs       TimeLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, workflowKey])
  @@index([organizationId, sortOrder])
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  notes          String?
  projects       Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Project {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  clientId            String
  client              Client       @relation(fields: [clientId], references: [id])
  currentDepartmentId String?
  currentDepartment   Department?  @relation(fields: [currentDepartmentId], references: [id])

  name          String
  jobNumber     String?
  description   String?
  status        ProjectStatus @default(ACTIVE)
  priority      Priority      @default(NORMAL)
  dueDate       DateTime?
  installDate   DateTime?
  isBlocked     Boolean       @default(false)
  blockedReason String?

  areas            Area[]
  cabinetItems     CabinetItem[]
  tasks            Task[]
  notes            Note[]
  files            File[]
  photos           Photo[]
  notifications    Notification[]
  timeLogs         TimeLog[]
  timeClockEntries TimeClockEntry[]
  calendarEvents   CalendarEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, jobNumber])
  @@index([organizationId, status])
  @@index([clientId])
  @@index([currentDepartmentId])
}

model Area {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  name        String
  description String?
  sortOrder   Int     @default(0)

  cabinetItems CabinetItem[]
  tasks        Task[]
  notes        Note[]
  files        File[]
  photos       Photo[]
  timeLogs     TimeLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, sortOrder])
}

model CabinetItem {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  areaId    String?
  area      Area?   @relation(fields: [areaId], references: [id])

  name        String
  itemNumber  String?
  itemType    CabinetItemType   @default(OTHER)
  description String?
  status      CabinetItemStatus @default(PLANNED)
  quantity    Int               @default(1)
  width       Decimal?
  height      Decimal?
  depth       Decimal?
  material    String?
  finish      String?
  hardware    String?

  tasks    Task[]
  notes    Note[]
  files    File[]
  photos   Photo[]
  timeLogs TimeLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([areaId])
}

model Task {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id])
  areaId        String?
  area          Area?        @relation(fields: [areaId], references: [id])
  cabinetItemId String?
  cabinetItem   CabinetItem? @relation(fields: [cabinetItemId], references: [id])
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById   String?
  createdBy     User?        @relation("TaskCreator", fields: [createdById], references: [id])

  title         String
  description   String?
  status        TaskStatus @default(TODO)
  priority      Priority   @default(NORMAL)
  dueDate       DateTime?
  completedAt   DateTime?
  isBlocked     Boolean    @default(false)
  blockedReason String?

  notes    Note[]
  files    File[]
  photos   Photo[]
  timeLogs TimeLog[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  timeClockEntries TimeClockEntry[]

  @@index([projectId])
  @@index([departmentId, status])
  @@index([assigneeId])
  @@index([dueDate])
}

model Note {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id])
  areaId        String?
  area          Area?        @relation(fields: [areaId], references: [id])
  cabinetItemId String?
  cabinetItem   CabinetItem? @relation(fields: [cabinetItemId], references: [id])
  taskId        String?
  task          Task?        @relation(fields: [taskId], references: [id])
  authorId      String
  author        User         @relation(fields: [authorId], references: [id])

  body     String
  noteType NoteType @default(GENERAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, createdAt])
  @@index([authorId])
}

model File {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id])
  areaId        String?
  area          Area?        @relation(fields: [areaId], references: [id])
  cabinetItemId String?
  cabinetItem   CabinetItem? @relation(fields: [cabinetItemId], references: [id])
  taskId        String?
  task          Task?        @relation(fields: [taskId], references: [id])
  uploadedById  String
  uploadedBy    User         @relation(fields: [uploadedById], references: [id])
  sourceFileId  String?
  sourceFile    File?        @relation("FileRevisions", fields: [sourceFileId], references: [id], onDelete: SetNull)
  revisions     File[]       @relation("FileRevisions")
  lastMarkedUpById String?
  lastMarkedUpBy   User?     @relation("FileLastMarkedUpBy", fields: [lastMarkedUpById], references: [id], onDelete: SetNull)

  name        String
  storagePath String
  mimeType    String?
  sizeBytes   Int?
  fileType    FileType @default(DOCUMENT)
  markupJson  Json?
  pageRotations Json?
  deletedPages Json?
  lastMarkedUpAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, createdAt])
  @@index([uploadedById])
  @@index([sourceFileId])
  @@index([lastMarkedUpById])
}

model Photo {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id])
  areaId        String?
  area          Area?        @relation(fields: [areaId], references: [id])
  cabinetItemId String?
  cabinetItem   CabinetItem? @relation(fields: [cabinetItemId], references: [id])
  taskId        String?
  task          Task?        @relation(fields: [taskId], references: [id])
  uploadedById  String
  uploadedBy    User         @relation(fields: [uploadedById], references: [id])

  caption     String?
  storagePath String
  mimeType    String?
  sizeBytes   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, createdAt])
  @@index([uploadedById])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  type   NotificationType
  title  String
  body   String?
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([projectId])
}

model Conversation {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  createdById    String?
  createdBy      User?             @relation("ConversationCreator", fields: [createdById], references: [id])

  title String?
  type  ConversationType @default(DIRECT)

  participants ConversationParticipant[]
  messages     ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, updatedAt])
  @@index([createdById])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadAt DateTime?
  createdAt  DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])

  body      String
  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model CalendarEvent {
  id             String                  @id @default(cuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User                    @relation(fields: [createdById], references: [id])
  projectId      String?
  project        Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)

  title       String
  description String?
  eventType   CalendarEventType          @default(GENERAL)
  visibility  CalendarEventVisibility    @default(PERSONAL)
  startsAt    DateTime
  endsAt      DateTime?
  color       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, startsAt])
  @@index([createdById, startsAt])
  @@index([projectId, startsAt])
}

model TimeLog {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id])
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  areaId        String?
  area          Area?        @relation(fields: [areaId], references: [id])
  cabinetItemId String?
  cabinetItem   CabinetItem? @relation(fields: [cabinetItemId], references: [id])
  taskId        String?
  task          Task?        @relation(fields: [taskId], references: [id])

  minutes  Int
  workDate DateTime
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, workDate])
  @@index([userId, workDate])
  @@index([departmentId])
}

model TimeClockEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  taskId         String?
  task           Task?        @relation(fields: [taskId], references: [id])

  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  source           String    @default("MANUAL")
  verificationNote String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, endedAt])
  @@index([userId, endedAt])
  @@index([projectId])
  @@index([taskId])
}

enum UserRole {
  OWNER_ADMIN
  MANAGER
  SALES
  DESIGNER
  PURCHASER
  SHOP_LEAD
  DEPARTMENT_USER
  INSTALLER
}

enum DepartmentKey {
  SALES
  DESIGN
  APPROVAL
  SCHEDULING
  PURCHASING
  CUT_MILL
  FACE_FRAME
  ASSEMBLY
  SAND_PREP
  FINISH
  FINAL_ASSEMBLY
  QC
  DELIVERY
  INSTALL
  CLOSEOUT
}

enum ProjectStatus {
  LEAD
  ACTIVE
  ON_HOLD
  BLOCKED
  COMPLETE
  CANCELED
}

enum TaskStatus {
  TODO
  READY
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CabinetItemType {
  BASE
  WALL
  TALL
  VANITY
  PANEL
  ISLAND
  TRIM
  OTHER
}

enum CabinetItemStatus {
  PLANNED
  APPROVED
  IN_PRODUCTION
  COMPLETE
  INSTALLED
}

enum NoteType {
  GENERAL
  APPROVAL
  CHANGE
  ISSUE
  QC
  INSTALL
}

enum FileType {
  DOCUMENT
  DRAWING
  APPROVAL
  CUT_LIST
  HARDWARE
  OTHER
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE
  TASK_BLOCKED
  PROJECT_STAGE_CHANGED
  FILE_UPLOADED
  NOTE_ADDED
  CHAT_MESSAGE
}

enum ConversationType {
  DIRECT
  GROUP
}

enum CalendarEventVisibility {
  PERSONAL
  COMPANY
}

enum CalendarEventType {
  GENERAL
  MEETING
  DELIVERY
  INSTALL
  DEADLINE
}
